generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Tahun Anggaran (Fiscal Year)
model TahunAnggaran {
  id        String   @id @default(cuid())
  tahun     Int      @unique
  aktif     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pendapatan    Pendapatan[]
  belanja       Belanja[]
  pembiayaan    Pembiayaan[]
  realisasiAkun RealisasiAkun[]
  realisasiSkpd RealisasiSkpd[]
  opd           Opd[]
}

// Pendapatan Daerah (Regional Revenue)
model Pendapatan {
  id              String   @id @default(cuid())
  tahunAnggaranId String
  kodeAkun        String
  namaAkun        String
  kategori        String   // PAD, Transfer, Lainnya
  anggaran        Float    // Budget amount
  realisasi       Float    // Actual realization
  opdId           String?  // Link to OPD (null = global data, not tied to specific OPD)
  tanggalUpdate   DateTime @default(now()) // Tanggal update realisasi terakhir
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tahunAnggaran TahunAnggaran @relation(fields: [tahunAnggaranId], references: [id])
  opd           Opd?          @relation(fields: [opdId], references: [id])
  riwayat       PendapatanHistory[]
}

// Riwayat Update Pendapatan
model PendapatanHistory {
  id              String   @id @default(cuid())
  pendapatanId    String
  realisasiLama   Float
  realisasiBaru   Float
  tanggalUpdate   DateTime
  keterangan      String?
  updatedBy       String?
  createdAt DateTime      @default(now())

  pendapatan Pendapatan @relation(fields: [pendapatanId], references: [id], onDelete: Cascade)
}

// Belanja Daerah (Regional Expenditure)
model Belanja {
  id              String   @id @default(cuid())
  tahunAnggaranId String
  kodeAkun        String
  namaAkun        String
  kategori        String   // Operasi, Modal, Tak Terduga, Transfer
  anggaran        Float
  realisasi       Float
  opdId           String?  // Link to OPD (null = global data, not tied to specific OPD)
  tanggalUpdate   DateTime @default(now()) // Tanggal update realisasi terakhir
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tahunAnggaran TahunAnggaran @relation(fields: [tahunAnggaranId], references: [id])
  opd           Opd?          @relation(fields: [opdId], references: [id])
  riwayat       BelanjaHistory[]
}

// Riwayat Update Belanja
model BelanjaHistory {
  id              String   @id @default(cuid())
  belanjaId       String
  realisasiLama   Float
  realisasiBaru   Float
  tanggalUpdate   DateTime
  keterangan      String?
  updatedBy       String?
  createdAt DateTime      @default(now())

  belanja Belanja @relation(fields: [belanjaId], references: [id], onDelete: Cascade)
}

// Pembiayaan (Financing)
model Pembiayaan {
  id              String   @id @default(cuid())
  tahunAnggaranId String
  kodeAkun        String
  namaAkun        String
  kategori        String   // Penerimaan, Pengeluaran
  anggaran        Float
  realisasi       Float
  opdId           String?  // Link to OPD (null = global data, not tied to specific OPD)
  tanggalUpdate   DateTime @default(now()) // Tanggal update realisasi terakhir
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tahunAnggaran TahunAnggaran @relation(fields: [tahunAnggaranId], references: [id])
  opd           Opd?          @relation(fields: [opdId], references: [id])
  riwayat       PembiayaanHistory[]
}

// Riwayat Update Pembiayaan
model PembiayaanHistory {
  id              String   @id @default(cuid())
  pembiayaanId    String
  realisasiLama   Float
  realisasiBaru   Float
  tanggalUpdate   DateTime
  keterangan      String?
  updatedBy       String?
  createdAt DateTime      @default(now())

  pembiayaan Pembiayaan @relation(fields: [pembiayaanId], references: [id], onDelete: Cascade)
}

// Realisasi Per-Akun (Realization per Account)
model RealisasiAkun {
  id              String   @id @default(cuid())
  tahunAnggaranId String
  kodeAkun        String   // Kode induk 2 digit, e.g., "4.1"
  namaAkun        String
  jenis           String   // Pendapatan, Belanja, Pembiayaan
  anggaran        Float
  realisasi       Float
  persentase      Float
  autoSync        Boolean  @default(false) // true = auto-generated from Pendapatan/Belanja/Pembiayaan
  tanggalUpdate   DateTime @default(now()) // Tanggal update realisasi terakhir
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tahunAnggaran TahunAnggaran @relation(fields: [tahunAnggaranId], references: [id])
  riwayat       RealisasiAkunHistory[]
}

// Riwayat Update Realisasi Akun
model RealisasiAkunHistory {
  id              String   @id @default(cuid())
  realisasiAkunId String
  realisasiLama   Float    // Nilai realisasi sebelum update
  realisasiBaru   Float    // Nilai realisasi setelah update
  persentaseBaru  Float    // Persentase setelah update
  tanggalUpdate   DateTime // Tanggal saat update dilakukan
  keterangan      String?  // Keterangan tambahan (opsional)
  updatedBy       String?  // Nama user yang melakukan update
  createdAt DateTime      @default(now())

  realisasiAkun RealisasiAkun @relation(fields: [realisasiAkunId], references: [id], onDelete: Cascade)
}

// Realisasi Per-SKPD (Realization per Government Unit)
model RealisasiSkpd {
  id              String   @id @default(cuid())
  tahunAnggaranId String
  kodeSkpd        String
  namaSkpd        String
  anggaran        Float
  realisasi       Float
  persentase      Float
  autoSync        Boolean  @default(false) // true = auto-generated from Pendapatan/Belanja/Pembiayaan per OPD
  tanggalUpdate   DateTime @default(now()) // Tanggal update realisasi terakhir
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tahunAnggaran TahunAnggaran @relation(fields: [tahunAnggaranId], references: [id])
  riwayat       RealisasiSkpdHistory[]
}

// Riwayat Update Realisasi SKPD
model RealisasiSkpdHistory {
  id              String   @id @default(cuid())
  realisasiSkpdId String
  realisasiLama   Float    // Nilai realisasi sebelum update
  realisasiBaru   Float    // Nilai realisasi setelah update
  persentaseBaru  Float    // Persentase setelah update
  tanggalUpdate   DateTime // Tanggal saat update dilakukan
  keterangan      String?  // Keterangan tambahan (opsional)
  updatedBy       String?  // Nama user yang melakukan update
  createdAt DateTime      @default(now())

  realisasiSkpd RealisasiSkpd @relation(fields: [realisasiSkpdId], references: [id], onDelete: Cascade)
}

// OPD - Organisasi Perangkat Daerah (Regional Government Organizations)
model Opd {
  id              String   @id @default(cuid())
  tahunAnggaranId String
  kodeOpd         String   // Kode OPD, e.g., "1.01.01"
  namaOpd         String   // Nama OPD, e.g., "Dinas Pendidikan"
  kepalaOpd       String?  // Nama Kepala OPD
  alamat          String?  // Alamat kantor
  telepon         String?  // Nomor telepon
  email           String?  // Email resmi
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tahunAnggaran TahunAnggaran @relation(fields: [tahunAnggaranId], references: [id])
  pendapatan    Pendapatan[]
  belanja       Belanja[]
  pembiayaan    Pembiayaan[]
  users         User[]
}

// Kategori - Dynamic categories for Pendapatan, Belanja, Pembiayaan, Realisasi Akun
model Kategori {
  id              String   @id @default(cuid())
  jenis           String   // "Pendapatan", "Belanja", "Pembiayaan", "RealisasiAkun"
  namaKategori    String   // e.g., "PAD", "Operasi", "Penerimaan"
  kodeKategori    String?  // Optional short code
  urutan          Int      @default(0) // Display order
  aktif           Boolean  @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([jenis, namaKategori])
}

// User - Admin & OPD users for authentication
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String   // Hashed password (bcrypt)
  role          String   @default("admin") // "admin", "superadmin", or "opd"
  opdId         String?  // Link to OPD (only for role="opd")
  aktif         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  opd           Opd?     @relation(fields: [opdId], references: [id])
}

// Pengaturan Aplikasi (Application Settings)
model PengaturanAplikasi {
  id              String   @id @default(cuid())
  namaAplikasi    String   @default("Dashboard Keuangan")
  namaPemerintah  String   @default("Pemerintah Kabupaten Seruyan")
  namaInstansi    String   @default("BKAD Kab. Seruyan")  // Nama instansi/OPD pengelola (ditampilkan di sidebar, login, dll)
  warnaPrimary    String   @default("#1B5E20")    // Sidebar & header primary
  warnaSecondary  String   @default("#2E7D32")    // Gradient secondary
  warnaAccent     String   @default("#F9A825")    // Gold accent
  warnaDark       String   @default("#0D3B12")    // Darkest shade
  logoBase64      String?  // Base64 encoded logo image
  logoUrl         String?  // URL for logo (fallback)
  alamatInstansi  String?  // Alamat instansi
  teleponInstansi String?  // Telepon instansi
  emailInstansi   String?  // Email instansi
  websiteInstansi String?  // Website instansi
  setupComplete   Boolean  @default(false) // True after setup wizard is completed
  aktif           Boolean  @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
